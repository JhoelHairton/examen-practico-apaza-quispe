{
  "__inputs": [
    {
      "name": "DS_ELASTICSEARCH",
      "label": "Elasticsearch (Wazuh)",
      "description": "Datasource Elasticsearch que apunta a wazuh-alerts-*",
      "type": "datasource",
      "pluginId": "elasticsearch",
      "pluginName": "Elasticsearch"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "elasticsearch",
      "name": "Elasticsearch",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 10,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# SOC - Monitor de Seguridad\n**Curso:** Seguridad Informatica (Unidad IV) &nbsp;|&nbsp; **Autor:** Jhoel AQ &nbsp;|&nbsp; **Fuente:** Wazuh (indice `wazuh-alerts-*`) &nbsp;|&nbsp; **Ventana:** ultimas 24 horas\n\nPanel de monitoreo de eventos de seguridad correlacionados por Wazuh."
      }
    },
    {
      "id": 1,
      "type": "barchart",
      "title": "V1 - Conteo de alertas por nivel de severidad (rule.level)",
      "datasource": {
        "type": "elasticsearch",
        "uid": "${DS_ELASTICSEARCH}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        },
        "xTickLabelRotation": 0,
        "stacking": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "${DS_ELASTICSEARCH}"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "rule.level",
              "settings": {
                "order": "asc",
                "orderBy": "_term",
                "size": "20",
                "min_doc_count": "0"
              }
            }
          ],
          "timeField": "@timestamp"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "V2 - Top 10 IPs de origen con mas alertas (data.srcip)",
      "datasource": {
        "type": "elasticsearch",
        "uid": "${DS_ELASTICSEARCH}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "${DS_ELASTICSEARCH}"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "data.srcip",
              "settings": {
                "order": "desc",
                "orderBy": "1",
                "size": "10"
              }
            }
          ],
          "timeField": "@timestamp"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "V3 - Alertas por hora (ultimas 24h)",
      "datasource": {
        "type": "elasticsearch",
        "uid": "${DS_ELASTICSEARCH}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "${DS_ELASTICSEARCH}"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": {
                "interval": "1h",
                "min_doc_count": "0",
                "trimEdges": "0"
              }
            }
          ],
          "timeField": "@timestamp"
        }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "V4 - Distribucion por tipo de regla (rule.groups)",
      "datasource": {
        "type": "elasticsearch",
        "uid": "${DS_ELASTICSEARCH}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "${DS_ELASTICSEARCH}"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "rule.groups",
              "settings": {
                "order": "desc",
                "orderBy": "1",
                "size": "10"
              }
            }
          ],
          "timeField": "@timestamp"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "V5 - Eventos recientes (Raw Data) - exportar 20 registros a CSV (Tarea 4.1)",
      "description": "Panel auxiliar para la Tarea 4.1: muestra los ultimos eventos crudos de wazuh-alerts-*. Exportar con el menu del panel (arriba a la derecha) -> Inspect -> Data -> Download CSV.",
      "datasource": {
        "type": "elasticsearch",
        "uid": "${DS_ELASTICSEARCH}"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "${DS_ELASTICSEARCH}"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "raw_data",
              "settings": {
                "size": "20"
              }
            }
          ],
          "bucketAggs": [],
          "timeField": "@timestamp"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": [
    "wazuh",
    "soc",
    "seguridad-informatica"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
